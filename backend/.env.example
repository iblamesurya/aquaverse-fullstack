# Server Configuration
PORT=5000
NODE_ENV=development
HOST=localhost

# Frontend URLs
FRONTEND_URL=http://localhost:3000
FRONTEND_PROD_URL=https://aquaverse.vercel.app

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/aquaverse
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/aquaverse

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# Google Genkit AI Configuration
GENKIT_API_KEY=YOUR_GENKIT_API_KEY_HERE
GENKIT_MODEL=gemini-1.5-pro
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# Prawn Disease Diagnosis AI
DIAGNOSIS_MODEL=gemini-1.5-pro
DIAGNOSIS_TEMPERATURE=0.7

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@aquaverse.app

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ORIGIN=http://localhost:3000,https://aquaverse.vercel.app

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# API Documentation
API_DOCS_ENABLED=true
API_DOCS_PATH=/api/docs
