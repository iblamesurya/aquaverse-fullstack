# Frontend Environment Variables

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_API_PRODUCTION_URL=https://aquaverse-api.onrender.com

# Environment
NEXT_PUBLIC_ENV=development

# Google Genkit AI Configuration (Frontend)
NEXT_PUBLIC_GENKIT_API_KEY=YOUR_GENKIT_API_KEY_HERE
NEXT_PUBLIC_GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# Vercel Analytics (Optional)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your_analytics_id

# Feature Flags
NEXT_PUBLIC_ENABLE_AI_DIAGNOSIS=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_THEME_TOGGLE=true

# Application Settings
NEXT_PUBLIC_APP_NAME=Aquaverse
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_COMPANY_NAME=Aquaculture AI Labs

# API Timeouts (in milliseconds)
NEXT_PUBLIC_API_TIMEOUT=30000

# Debug Mode (set to true only in development)
NEXT_PUBLIC_DEBUG=false
